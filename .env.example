# Config machine — édité une fois au déploiement.
# Les credentials Spotify (client_id, secret, playlist_id) se configurent via
# l'UI admin, pas ici. Voir README pour le détail.

# URL de callback OAuth Spotify (doit matcher ce qui est dans le dashboard Spotify)
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5001/callback

# Port sur lequel l'app écoute
PORT=5001

# Mot de passe d'accès à /admin
ADMIN_PASSWORD=change_me

# Clé secrète pour les sessions Flask (optionnel, sinon valeur par défaut)
# SECRET_KEY=generate_a_random_string

# --- Migration depuis une ancienne installation (optionnel) ---
# Si tu avais déjà des creds dans le .env d'une ancienne version, tu peux les
# laisser ici le temps du premier lancement : ils seront automatiquement migrés
# dans config/salles.json au démarrage, puis plus jamais utilisés.
# SPOTIFY_POP_CLIENT_ID=
# SPOTIFY_POP_CLIENT_SECRET=
# SPOTIFY_POP_PLAYLIST_ID=
# SPOTIFY_NOSTALGIE_CLIENT_ID=
# SPOTIFY_NOSTALGIE_CLIENT_SECRET=
# SPOTIFY_NOSTALGIE_PLAYLIST_ID=
